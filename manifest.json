{
  "manifest_version": 3,
  "name": "PromptVault",
  "version": "1.0.0",
  "description": "113 AI prompts with {{variable}} substitution. Click prompts in your browser toolbar, fill the blanks, copy to ChatGPT / Claude / Cursor / Midjourney.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "PromptVault — 113 AI prompts",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["clipboardWrite", "storage"],
  "homepage_url": "https://jiejuefuyou.github.io/prompts.html"
}
